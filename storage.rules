// Firebase Storage Security Rules — BioInteraction Algérie
//
// Déployer via Firebase Console > Storage > Rules
// ou via Firebase CLI : `firebase deploy --only storage`
//
// Principes :
// - Tout est interdit par défaut (deny-all baseline).
// - Les images du blog sont en lecture publique (affichées sur le site public).
// - L'écriture (upload/suppression) est réservée à l'admin, limitée aux images
//   et plafonnée à 10 Mo — empêche tout utilisateur inscrit (même "pending")
//   d'uploader des fichiers arbitraires.

rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Admin via email configuré OU rôle "admin" stocké dans Firestore.
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'admin@biointeractiondz.com' ||
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isValidImageUpload() {
      return request.resource.size < 10 * 1024 * 1024
          && request.resource.contentType.matches('image/.*');
    }

    // Images insérées dans le corps des articles
    match /blog-images/{allPaths=**} {
      allow read:  if true;
      allow write: if isAdmin() && isValidImageUpload();
    }

    // Images de couverture des articles
    match /blog-covers/{allPaths=**} {
      allow read:  if true;
      allow write: if isAdmin() && isValidImageUpload();
    }

    // Tout le reste — interdit
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
